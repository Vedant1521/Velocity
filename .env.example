# ==========================================
# 🚀 CORE APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
APP_PORT=3001
FRONTEND_URL=http://localhost:3000

# ==========================================
# 🔑 SECURITY & SESSION ACCESS KEYS
# ==========================================
# Secret key used to sign and verify session JWTs
JWT_SECRET=your_jwt_secret_key_here
# Hex-encoded 32-byte key used to encrypt OAuth refresh tokens (64 characters)
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f


# ==========================================
# 💾 DATABASE & REDIS INFRASTRUCTURE
# ==========================================
# PostgreSQL Connection URL
PG_CONNECTION_STRING=postgresql://username:password@localhost:5432/velocity

# Redis connection details
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# ==========================================
# 🤖 AI & LLM CONFIGURATION (AZURE OPENAI)
# ==========================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=

# ==========================================
# 🔌 THIRD-PARTY INTEGRATION CHANNELS
# ==========================================
# Google (Gmail Sync OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback/google
GOOGLE_CONNECT_REDIRECT_URI=http://localhost:3001/api/connect/callback/google
GMAIL_PUBSUB_TOPIC=

# Microsoft (Outlook Sync OAuth)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3001/api/auth/callback/outlook
OUTLOOK_CONNECT_REDIRECT_URI=http://localhost:3001/api/connect/callback/outlook
OUTLOOK_WEBHOOK_URL=
MICROSOFT_TENANT_ID=
OUTLOOK_CLIENT_STATE=

# Telegram Integration Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Cloudinary (Screenshot Storage)
CLOUDINARY_CLOUDNAME=

# ==========================================
# 💳 PAYMENT & SUBSCRIPTION GATEWAYS (STRIPE)
# ==========================================
STRIPE_SECRET_KEY=
STARTER_PRICE_ID=
PRO_PRICE_ID=
BUSINESS_PRICE_ID=

# ==========================================
# 📡 TELEMETRY, LOGGING, & ANALYTICS
# ==========================================
SENTRY_DSN=
